# Cadena de conexión a PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Genera uno con: openssl rand -base64 32
AUTH_SECRET="sustituye-por-un-secreto-largo-y-aleatorio"

# URL base de la aplicación (en producción: https://tu-dominio.com)
AUTH_URL="http://localhost:3000"

# En Vercel: misma URL pública que ves en el navegador, p. ej. https://tu-app.vercel.app (requerido para cookies/sesión).
# NEXT_PUBLIC_APP_URL="https://tu-dominio.com"

# -----------------------------------------------------------------------------
# Superadministradores (solo aquí; no se crean desde la web)
# -----------------------------------------------------------------------------
# Un JSON en UNA línea, entre comillas simples. Varios objetos = varios admins.
#
# Estructura equivalente (para que la veas clara; en .env usa solo la línea SUPERADMIN_ACCOUNTS):
# [
#   { "email": "admin@empresa.com",    "password": "tu-clave-1" },
#   { "email": "otro@empresa.com",     "password": "tu-clave-2" }
# ]
#
# Ejemplo listo para copiar (cambia correos y contraseñas antes de producción):

SUPERADMIN_ACCOUNTS='[{"email":"admin@example.com","password":"CambiarEstaClave123"},{"email":"supervisor@example.com","password":"OtraClave456"}]'
