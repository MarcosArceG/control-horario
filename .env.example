# Cadena de conexión a PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Genera uno con: openssl rand -base64 32
AUTH_SECRET="sustituye-por-un-secreto-largo-y-aleatorio"

# Local: http://localhost:3000  |  Producción (Vercel): SIEMPRE https:// (nunca http://)
AUTH_URL="http://localhost:3000"

# En Vercel: misma URL pública que ves en el navegador, con https://
# Ej.: AUTH_URL=https://triclock.gestiondelamianto.com
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# -----------------------------------------------------------------------------
# Superadministradores (solo aquí; no se crean desde la web)
# -----------------------------------------------------------------------------
# Opción A (recomendada en Vercel): una variable por campo, numeradas 1, 2, 3…
# Cada índice debe ser distinto (AUTH_USER_3_* para el tercer usuario, no repetir _2).
#
# AUTH_USER_1_EMAIL="admin@empresa.com"
# AUTH_USER_1_PASSWORD="tu-clave"
# AUTH_USER_2_EMAIL="otro@empresa.com"
# AUTH_USER_2_PASSWORD="otra-clave"
#
# Opción B (opcional): SUPERADMIN_ACCOUNTS como JSON en una línea; se fusiona
# con la opción A (los numerados mandan si el correo coincide).
#
# SUPERADMIN_ACCOUNTS='[{"email":"admin@example.com","password":"CambiarEstaClave123"}]'
